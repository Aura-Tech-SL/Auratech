# Base de dades
DATABASE_URL="postgresql://user:password@localhost:5432/auratech?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-secret-aleatori-aqui"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM="Auratech <noreply@auratech.cat>"
# Comma-separated list supported. Primary recipient (To)
CONTACT_NOTIFY_EMAIL="oscar.rovira@auratech.cat"
# Optional CC list (comma-separated)
CONTACT_NOTIFY_CC=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Auratech"

# Sentry (production-only — leave empty in dev, errors won't be sent)
# DSN goes to both client and server bundles via NEXT_PUBLIC_*
NEXT_PUBLIC_SENTRY_DSN=""
# Build-time only (CI), used to upload source maps
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# OVH API — DNS automation for auratech.cat zone
# Token scope: GET/PUT/POST/DELETE on /domain/zone/auratech.cat/*
# Generate at https://eu.api.ovh.com/createToken/?GET=/domain/zone/auratech.cat/*&PUT=/domain/zone/auratech.cat/*&POST=/domain/zone/auratech.cat/*&DELETE=/domain/zone/auratech.cat/*
OVH_API_KEY=""
OVH_API_SECRET=""
OVH_CONSUMER_KEY=""
OVH_API_REGION="eu"
